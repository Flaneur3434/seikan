{
    "configurations": [
        {
            "name": "ESP-IDF",
            "compileCommands": "${workspaceFolder}/wireguard-baremetal/build/compile_commands.json",
            "includePath": [
                "/opt/esp-idf/components/**",
                "${workspaceFolder}/wireguard-baremetal/platform/main",
                "${workspaceFolder}/wireguard-baremetal/platform/common/include",
                "${workspaceFolder}/wireguard-baremetal/platform/cortex_m/include",
                "${workspaceFolder}/wireguard-baremetal/build/config"
            ],
            "defines": [
                "ESP_PLATFORM",
                "IDF_TARGET_ESP32C6"
            ],
            "cStandard": "c23",
            "cppStandard": "c++17",
            "intelliSenseMode": "linux-gcc-x64",
            "browse": {
                "path": [
                    "/opt/esp-idf/components",
                    "${workspaceFolder}/wireguard-baremetal"
                ],
                "limitSymbolsToIncludedHeaders": true
            }
        }
    ],
    "version": 4
}
