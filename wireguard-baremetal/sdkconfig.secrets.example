# WiFi and WireGuard secrets — DO NOT COMMIT
# Copy sdkconfig.secrets.example to sdkconfig.secrets and fill in values.

CONFIG_WIFI_SSID="your-ssid"
CONFIG_WIFI_PASSWORD="your-password"

CONFIG_WG_STATIC_PRIVATE_KEY=""
CONFIG_WG_PEER_PUBLIC_KEY=""
CONFIG_WG_PRESHARED_KEY=""

CONFIG_WG_PEER2_PUBLIC_KEY=""
CONFIG_WG_PEER2_PRESHARED_KEY=""
