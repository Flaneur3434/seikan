# ============================================================================
# Seikan Reproducible Build Container
# ============================================================================
#
# Provides: ESP-IDF + Alire + GNAT RISC-V cross-compiler + GNATprove
#
# Target: ESP32-C6 (RISC-V) by default.  Change IDF_TARGET build arg for others.
#
# Build:
#   podman build -t veriguard-build -f Containerfile .
#
# Usage (via build.py):
#   ./build.py build --container
#
# Manual usage:
#   podman run --rm -v ./:/work:Z veriguard-build build --release
#
# ============================================================================

FROM ubuntu:24.04 AS base

ARG DEBIAN_FRONTEND=noninteractive

# ── Pinned versions (edit here to bump) ─────────────────────────────────────
ARG ESP_IDF_VERSION=v5.5.3
ARG IDF_TARGET=esp32c6
ARG ALIRE_VERSION=2.1.0
ARG GNAT_RISCV64_VERSION=15.2.1
ARG GPRBUILD_VERSION=25.0.1

# ── System packages ─────────────────────────────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
        git wget curl ca-certificates \
        python3 python3-pip python3-venv \
        cmake ninja-build \
        build-essential \
        libusb-1.0-0 \
        flex bison gperf \
        ccache dfu-util \
        libffi-dev libssl-dev \
        unzip xz-utils \
    && rm -rf /var/lib/apt/lists/*

# ── ESP-IDF ─────────────────────────────────────────────────────────────────
# Clone at the pinned release tag for reproducibility.
ENV IDF_PATH=/opt/esp-idf
ENV IDF_TOOLS_PATH=/opt/espressif

RUN git clone --branch "$ESP_IDF_VERSION" --depth 1 --recursive \
        https://github.com/espressif/esp-idf.git "$IDF_PATH"

# Install ESP-IDF toolchains for the target chip only (saves ~1 GB vs all targets)
RUN cd "$IDF_PATH" \
    && ./install.sh "$IDF_TARGET" \
    && ./install.sh --enable-pytest

# ── Alire ───────────────────────────────────────────────────────────────────
ENV ALIRE_HOME=/opt/alire

RUN ARCH=$(dpkg --print-architecture) \
    && case "$ARCH" in \
         amd64) ALR_ARCH=x86_64 ;; \
         arm64) ALR_ARCH=aarch64 ;; \
         *) echo "Unsupported arch: $ARCH" && exit 1 ;; \
       esac \
    && wget -q "https://github.com/alire-project/alire/releases/download/v${ALIRE_VERSION}/alr-${ALIRE_VERSION}-bin-${ALR_ARCH}-linux.zip" \
         -O /tmp/alr.zip \
    && unzip -q /tmp/alr.zip -d /tmp/alr \
    && install -m 755 /tmp/alr/bin/alr /usr/local/bin/alr \
    && rm -rf /tmp/alr /tmp/alr.zip

# ── GNAT RISC-V cross-compiler + gprbuild (via Alire toolchains) ────────────
# These are installed system-wide so they persist in the image.
# --non-interactive prevents Alire from prompting.
RUN alr -n toolchain --select \
        "gnat_riscv64_elf=${GNAT_RISCV64_VERSION}" \
        "gprbuild=${GPRBUILD_VERSION}"

# ── GNATprove / SPARK (via `alr install`) ──────────────────────────────────
# gnatprove also pulls gnat_native as a dependency for host-side analysis.
RUN alr -n install gnatprove

# Ensure alr-installed binaries are on PATH
ENV PATH="/root/.alire/bin:${PATH}"

# Verify the toolchain is functional
RUN bash -c '. "$IDF_PATH/export.sh" && idf.py --version' \
    && alr toolchain \
    && gnatprove --version | head -1

# ── Python extras (keygen needs cryptography) ──────────────────────────────
RUN pip3 install --break-system-packages cryptography

# ── Entrypoint ──────────────────────────────────────────────────────────────
WORKDIR /work

# Source ESP-IDF environment and dispatch to build.py
COPY container-entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD ["build", "--release"]
