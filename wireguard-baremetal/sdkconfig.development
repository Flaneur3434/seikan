# ESP-IDF development build overrides
# Applied on top of sdkconfig.defaults when building with --development
#
# Enables GDB-friendly panic handling and verbose logging.

CONFIG_ESP_COREDUMP_ENABLE_TO_NONE=y

CONFIG_ESP_SYSTEM_PANIC_GDBSTUB=y

# Raise default log level to DEBUG for development
CONFIG_LOG_DEFAULT_LEVEL_DEBUG=y

CONFIG_LWIP_DEBUG=y

CONFIG_COMPILER_STACK_CHECK_MODE_NORM=y
