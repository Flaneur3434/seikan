with "config/tests_config.gpr";
with "crypto.gpr";
with "wireguard.gpr";
with "net.gpr";

project Tests is

   for Source_Dirs use ("src/", "src/unit/", "src/property/", "config/");
   for Object_Dir use "obj/" & Tests_Config.Build_Profile;
   for Exec_Dir use "bin";
   for Create_Missing_Dirs use "True";

   for Main use ("test_runner.adb");

   package Compiler is
      for Default_Switches ("Ada") use Tests_Config.Ada_Compiler_Switches;
   end Compiler;

   package Binder is
      for Switches ("Ada") use ("-Es"); --  Symbolic traceback
   end Binder;

   package Builder is
      for Executable ("test_runner.adb") use "run_tests";
   end Builder;

end Tests;
